Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Definizione", " ", "esplicita", " ", "con", " ", "parte", " ", "reale", " ",
     "e", " ", "immaginaria"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"U", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"a", "+", 
          RowBox[{"I", "*", "alpha"}]}], ",", 
         RowBox[{"b", "+", 
          RowBox[{"I", "*", "beta"}]}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"c", "+", 
          RowBox[{"I", "*", "gamma"}]}], ",", 
         RowBox[{"d", "+", 
          RowBox[{"I", "*", "delta"}]}]}], "}"}]}], "}"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"UUdagger", "=", 
     RowBox[{"ComplexExpand", "[", 
      RowBox[{"U", ".", 
       RowBox[{"ConjugateTranspose", "[", "U", "]"}]}], "]"}]}], ";"}], "\n", 
   
   RowBox[{
    RowBox[{"Id", "=", 
     RowBox[{"IdentityMatrix", "[", "2", "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"equazioniReali", "=", 
     RowBox[{"Thread", "[", 
      RowBox[{
       RowBox[{"Flatten", "[", "UUdagger", "]"}], "==", 
       RowBox[{"Flatten", "[", "Id", "]"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{"Column", "[", "equazioniReali", "]"}]}]}]], "Input",
